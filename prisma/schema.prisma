generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Lead {
  id                String   @id @default(cuid())
  nome              String
  empresa           String?
  nicho             String?
  cidade            String?
  telefone          String?
  whatsapp          String?
  telefoneRaw       String?
  whatsappRaw       String?
  email             String?
  temSite           Boolean  @default(false)
  siteFraco         Boolean  @default(false)
  instagramAtivo    Boolean  @default(false)
  gmbOtimizado      Boolean  @default(false)
  anunciosAtivos    Boolean  @default(false)
  opportunityScore  Int      @default(0)
  planoAtual        String?
  planoInicio       DateTime?
  planoAlvoUpgrade  String?
  upsellStatus      String   @default("NONE")
  score             String   @default("COLD")
  motivoScore       String?
  verbaAnuncios     Float?
  origem            String?
  decisionProfile   String?
  observacaoPerfil  String?
  pipelineStatus    String   @default("NEW")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  activities        Activity[]
  followUps         FollowUp[]
  proposals         Proposal[]
  tasks             InternalTask[]
  checklists        Checklist[]
  messages          Message[]
}

model Activity {
  id        String   @id @default(cuid())
  leadId    String
  tipo      String
  descricao String
  createdAt DateTime @default(now())
  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
}

model FollowUp {
  id           String   @id @default(cuid())
  leadId       String
  tipo         String
  mensagem     String?
  template     String?
  agendadoPara DateTime
  enviado      Boolean  @default(false)
  enviadoEm    DateTime?
  createdAt    DateTime @default(now())
  lead         Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
}

model Proposal {
  id          String   @id @default(cuid())
  leadId      String
  plano       String
  titulo      String
  conteudo    String
  status      String   @default("DRAFT")
  arquivoPath String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  lead        Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
}

model InternalTask {
  id         String    @id @default(cuid())
  leadId     String?
  titulo     String
  descricao  String?
  prioridade String    @default("MEDIUM")
  status     String    @default("PENDING")
  dueDate    DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  lead       Lead?     @relation(fields: [leadId], references: [id], onDelete: SetNull)
}

model Checklist {
  id        String          @id @default(cuid())
  leadId    String
  plano     String
  titulo    String
  createdAt DateTime        @default(now())
  lead      Lead            @relation(fields: [leadId], references: [id], onDelete: Cascade)
  items     ChecklistItem[]
}

model ChecklistItem {
  id          String    @id @default(cuid())
  checklistId String
  texto       String
  concluido   Boolean   @default(false)
  concluidoEm DateTime?
  checklist   Checklist @relation(fields: [checklistId], references: [id], onDelete: Cascade)
}

model Offer {
  id         String  @id @default(cuid())
  nome       String
  descricao  String?
  preco      Float
  precoSetup Float   @default(0)
  periodo    String  @default("mensal")
  ativo      Boolean @default(true)
  destaque   Boolean @default(false)
  features   String
}

model Objection {
  id        String   @id @default(cuid())
  objecao   String
  resposta  String
  categoria String?
  createdAt DateTime @default(now())
}

model Playbook {
  id        String   @id @default(cuid())
  titulo    String
  tipo      String
  conteudo  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Client {
  id          String         @id @default(cuid())
  leadId      String?        @unique
  nome        String
  empresa     String?
  nicho       String?
  cidade      String?
  telefone    String?
  whatsapp    String?
  email       String?
  planoAtual  String?
  planoInicio DateTime?
  mrr         Float          @default(0)
  status      String         @default("ACTIVE")
  nps         Int?
  observacoes String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  reports     ClientReport[]
}

model ClientReport {
  id          String    @id @default(cuid())
  clientId    String
  mes         String
  ano         Int
  leads       Int       @default(0)
  cliques     Int       @default(0)
  impressoes  Int       @default(0)
  conversoes  Int       @default(0)
  roas        Float?
  verba       Float?
  observacoes String?
  createdAt   DateTime  @default(now())
  client      Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
}

model MessageTemplate {
  id        String   @id @default(cuid())
  nome      String
  canal     String
  assunto   String?
  corpo     String
  categoria String?
  ativo     Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Campaign {
  id            String   @id @default(cuid())
  nome          String
  canal         String
  status        String   @default("DRAFT")
  templateId    String?
  destinatarios Int      @default(0)
  enviados      Int      @default(0)
  abertos       Int      @default(0)
  cliques       Int      @default(0)
  agendadoPara  DateTime?
  enviadaEm     DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Message {
  id           String   @id @default(cuid())
  leadId       String
  canal        String   // WHATSAPP | EMAIL
  destinatario String   // phone number or email address
  assunto      String?  // email subject
  corpo        String   // message body
  templateId   String?  // MessageTemplate used (if any)
  status       String   @default("PENDING") // PENDING | SENT | DELIVERED | FAILED
  externalId   String?  // ID from external API (Evolution/Resend)
  erro         String?  // error message if failed
  metadata     String?  // JSON: extra data (campaign, batch, etc.)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  lead         Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([leadId])
}

model ImportJob {
  id            String   @id @default(cuid())
  filename      String
  status        String   @default("running") // running | done | failed
  totalRows     Int      @default(0)
  imported      Int      @default(0)
  duplicated    Int      @default(0)
  invalid       Int      @default(0)
  processedRows Int      @default(0)
  logJson       String?
  createdAt     DateTime @default(now())
  finishedAt    DateTime?
}

// ─── Autenticação ──────────────────────────────────────────────────

model User {
  id           String   @id @default(cuid())
  nome         String
  email        String   @unique
  passwordHash String
  role         String   @default("USER") // USER | ADMIN
  ativo        Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}