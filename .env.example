# ══════════════════════════════════════════════════════════════════
# HIGHPLANS — Variáveis de Ambiente
# Copiar este ficheiro para .env e preencher os valores reais
# ══════════════════════════════════════════════════════════════════

# ─── Base de Dados (Supabase PostgreSQL) ──────────────────────────
# DATABASE_URL: URL com pooler (PgBouncer) — usada pela app em runtime
# DIRECT_URL:   URL directa (sem pooler) — usada pelo Prisma para migrations
#
# Encontre no Supabase Dashboard → Settings → Database → Connection String
DATABASE_URL="postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-1-eu-central-2.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres"

# ─── Autenticação (NextAuth v5) ──────────────────────────────────
# OBRIGATÓRIO: Segredo para assinar JWT tokens
# Gere com: openssl rand -hex 32
AUTH_SECRET="gere-um-segredo-aqui"
# Necessário em ambientes com proxy (Vercel, Docker)
AUTH_TRUST_HOST=true

# ─── WhatsApp Business (Evolution API) ───────────────────────────
# OPCIONAL: Se não configurado, sistema usa fallback wa.me (modo MANUAL)
EVOLUTION_API_URL="https://sua-instancia.evolution-api.com"
EVOLUTION_API_KEY="sua-api-key-evolution"
EVOLUTION_INSTANCE="highplans"

# ─── Email Transaccional (Resend) ────────────────────────────────
# OPCIONAL: Se não configurado, sistema usa fallback mailto: (modo MANUAL)
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx"
EMAIL_FROM="HIGHPLANS <noreply@seudominio.com>"

# ─── Segurança ────────────────────────────────────────────────────
# Token obrigatório para /api/seed (reset de dados, bloqueado em produção)
SEED_TOKEN="gere-um-token-seguro-aqui"
